        "id": "a6f6924677265583",
        "type": "function",
        "z": "3932f41790e8850a",
        "name": "function 1",
        "func": "let data = msg.payload;\n\nlet year = data.year;\nlet month = data.month;\nlet day = data.day;\n\nflow.set(\"year\", year);\nflow.set(\"month\", month);\nflow.set(\"day\", day);\n\nif (!year || !month || !day) {\n    msg.payload = \"-c \\\"print('Missing year/month/day')\\\"\";\n    return msg;\n}\n\nlet py = \"\";\npy += \"from natuurspotter import biodiversity_analysis, observations_map\\n\";\npy += \"year = \" + year + \"\\n\";\npy += \"month = \" + month + \"\\n\";\npy += \"day = '\" + day + \"'\\n\";\npy += \"biodiversity_analysis(month=month, year=year)\\n\";\npy += \"observations_map(day)\\n\";\npy += \"print('DONE')\\n\";\n\nmsg.payload =\n    \"-c \\\"\" +\n    py.replace(/\"/g, \"\\\\\\\"\").replace(/\\n/g, \"; \") +\n    \"\\\"\";\n\nreturn msg;",
