    {
        "id": "d73dad140f0e081a",
        "type": "function",
        "z": "3932f41790e8850a",
        "name": "summary",
        "func": "let rows = msg.payload;\n\n\nif (!Array.isArray(rows) || rows.length === 0) {\n    return null;\n}\n\nlet r = rows[0];\n\n\nlet m1 = {};\nm1.payload = Number(r.totalObservations);\n\nlet m2 = {};\nm2.payload = Number(r.species_richness);\n\nlet m3 = {};\nlet simpson = Number(r.simpson_diversity);\nm3.payload = Math.round(simpson * 1000) / 1000;  \n\nlet m4 = {};\nlet shannon = Number(r.shannon_diversity);\nm4.payload = Math.round(shannon * 100) / 100;     \n\nlet m5 = {};\nm5.payload = String(r.most_observed_species);\n\nreturn [m1, m2, m3, m4, m5];",
