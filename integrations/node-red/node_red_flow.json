    {
        "id": "93ab4bc456ce2f78",
        "type": "function",
        "z": "3932f41790e8850a",
        "name": "function 2",
        "func": "let rows = msg.payload;\n\nif (rows === undefined || rows === null) {\n    return [\n        { payload: [] },\n        { payload: [] },\n        { payload: \"No data available\" }\n    ];\n}\n\nif (rows.length === 0) {\n    return [\n        { payload: [] },\n        { payload: [] },\n        { payload: \"No data available\" }\n    ];\n}\n\nlet speciesCount = {};\n\nfor (let i = 0; i < rows.length; i++) {\n    let row = rows[i];\n\n    let species = row.species;\n    let count = Number(row.sum);\n\n    if (species === undefined) {\n        continue;\n    }\n\n    if (isNaN(count)) {\n        continue;\n    }\n\n    if (speciesCount[species] === undefined) {\n        speciesCount[species] = 0;\n    }\n\n    speciesCount[species] = speciesCount[species] + count;\n}\n\nlet speciesArray = [];\n\nfor (let speciesName in speciesCount) {\n    let obj = {};\n    obj.species = speciesName;\n    obj.observations = speciesCount[speciesName];\n\n    speciesArray.push(obj);\n}\n\nlet sortedDesc = [];\n\nfor (let i = 0; i < speciesArray.length; i++) {\n    sortedDesc.push(speciesArray[i]);\n}\n\nfor (let i = 0; i < sortedDesc.length; i++) {\n    for (let j = i + 1; j < sortedDesc.length; j++) {\n        if (sortedDesc[j].observations > sortedDesc[i].observations) {\n            let temp = sortedDesc[i];\n            sortedDesc[i] = sortedDesc[j];\n            sortedDesc[j] = temp;\n        }\n    }\n}\n\nlet sortedAsc = [];\n\nfor (let i = 0; i < speciesArray.length; i++) {\n    sortedAsc.push(speciesArray[i]);\n}\n\nfor (let i = 0; i < sortedAsc.length; i++) {\n    for (let j = i + 1; j < sortedAsc.length; j++) {\n        if (sortedAsc[j].observations < sortedAsc[i].observations) {\n            let temp = sortedAsc[i];\n            sortedAsc[i] = sortedAsc[j];\n            sortedAsc[j] = temp;\n        }\n    }\n}\n\nlet top20 = [];\n\nfor (let i = 0; i < 20 && i < sortedDesc.length; i++) {\n    top20.push(sortedDesc[i]);\n}\n\nlet bottom20 = [];\n\nfor (let i = 0; i < 20 && i < sortedAsc.length; i++) {\n    bottom20.push(sortedAsc[i]);\n}\n\n\nlet mostObservedText = \"Most observed species is \";\n\nif (top20.length > 0) {\n    mostObservedText =\n        mostObservedText +\n        top20[0].species +\n        \" (\" +\n        top20[0].observations +\n        \" observations)\";\n} else {\n    mostObservedText = mostObservedText + \"N/A\";\n}\n\nreturn [\n    { payload: top20 },           \n    { payload: bottom20 },        \n    { payload: mostObservedText } \n];",
        "outputs": 3,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
